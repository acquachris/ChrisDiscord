{
    "name": "chrisdiscord",
    "version": "1.3.22",
    "description": "A Discord Client Manager for Discord.js",
    "keywords": ["discord.js", "discord"],
    "homepage": "https://github.com/acquachris/ChrisDiscord#readme",
    "bugs": {
        "url": "https://github.com/acquachris/ChrisDiscord/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/acquachris/ChrisDiscord.git"
    },
    "license": "MIT",
    "author": "acquachris",

    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",

    "files": ["dist"],

    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
        "start": "node dist/index.js",
        "publish": "npm run build && npm publish --access=public"
    },

    "devDependencies": {
        "tsx": "^4.0.0",
        "typescript": "^5.9.3"
    },

    "dependencies": {
        "discord.js": "^14.25.1"
    }
}