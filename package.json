{
    "name": "chrisdiscord",
    "version": "1.3.15",
    "description": "A Discord Client Manager for Discord.js",
    "keywords": ["discord.js", "discord"],
    "homepage": "https://github.com/acquachris/ChrisDiscord#readme",
    "bugs": {
        "url": "https://github.com/acquachris/ChrisDiscord/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/acquachris/ChrisDiscord.git"
    },
    "license": "MIT",
    "author": "acquachris",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": ["dist"],
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node .",
        "publish": "npm publish --access=public"
    },
    "devDependencies": {
        "tsx": "^4.0.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "discord.js": "^14.25.1"
    }
}