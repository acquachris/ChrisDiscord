{
    "name": "chrisdiscord",
    "version": "1.3.11",
    "description": "A Discord Client Manager for Discord.js",
    "keywords": ["discord.js", "discord"],
    "homepage": "https://github.com/acquachris/ChrisDiscord#readme",
    "bugs": {
        "url": "https://github.com/acquachris/ChrisDiscord/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/acquachris/ChrisDiscord.git"
    },
    "license": "MIT",
    "author": "acquachris",
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": ["dist"],
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsdown",
        "start": "node .",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "tsdown": "^0.21.4",
        "tsx": "^4.0.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "discord.js": "^14.25.1"
    }
}