{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ESNext"],
        "outDir": "dist",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "events/*": ["src/events/*"],
            "interactions/*": ["src/interactions/*"],
            "client/*": ["src/client/*"],
            "types/*": ["src/types/*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}