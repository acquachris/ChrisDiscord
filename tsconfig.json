{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "lib": ["ESNext"],
        "moduleResolution": "Node",
        "moduleDetection": "force",
        "strict": true,
        "noImplicitAny": true,
        "declaration": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "resolveJsonModule": true,
        "outDir": "dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "events/*": ["src/events/*"],
            "interactions/*": ["src/interactions/*"],
            "client/*": ["src/client/*"],
            "types/*": ["src/types/*"]
        }
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}