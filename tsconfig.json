{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "lib": ["ESNext"],
        "moduleResolution": "Node",
        "outDir": "dist",
        "esModuleInterop": true,
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "events/*": ["src/events/*"],
            "interactions/*": ["src/interactions/*"],
            "client/*": ["src/client/*"],
            "types/*": ["src/types/*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"],
    "rewriteImports": true,
    "resolveExtensions": [".ts", ".js"]
}